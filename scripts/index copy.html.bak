    function today() {
      var d = new Date();
      return d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');
    }

    // --- Section extractor ---
    function extractSection(text, keyword, maxChars) {
      var lines = text.split('\n');
      var kw = keyword.toLowerCase();
      var startIdx = -1, startLevel = 0;
      for (var i = 0; i < lines.length; i++) {
        var m = lines[i].match(/^(#{1,6})\s+(.+)/);
        if (m && m[2].toLowerCase().includes(kw)) { startIdx = i; startLevel = m[1].length; break; }
      }
      if (startIdx === -1) {
        var notice = '[Section "' + keyword + '" not found — showing file start]\n\n';
        return notice + text.substring(0, maxChars - notice.length);
      }
      var content = '';
      for (var j = startIdx; j < lines.length; j++) {
        if (j > startIdx) {
          var next = lines[j].match(/^(#{1,6})\s/);
          if (next && next[1].length <= startLevel) break;
        }
        content += lines[j] + '\n';
        if (content.length >= maxChars) { content += '\n...[TRUNCATED — request a narrower section]'; break; }
      }
      return content;
    }

    // --- Actions ---

    function listCourses() {
      var store = getStore();
      var active = store.activeCourse ? '\n\nCurrently active: **' + store.activeCourse + '**' : '';
      return { result:
        'Your enrolled courses:\n\n' +
        '1. CMS707 — Artificial Intelligence\n' +
        '2. CMS701 — Operating Systems\n' +
        '3. CMS703 — Data Communications & Networks\n' +
        '4. CMS705 — Programming Languages\n' +
        '5. CMS709 — Compiler Construction\n' +
        '6. CMS711 — System Analysis & Design' + active +
        '\n\nType **[LT]** to learn a topic, **[KM]** for a knowledge map, **[GQ]** to take a quiz, or **[TP]** to see your progress.'
      };
    }

    function loadCourse(course) {
      var text = getEmbedded('cs-' + course);
      if (!text) return { error: 'Course "' + course + '" not found.' };
      var store = getStore(); store.activeCourse = course; saveStore(store);
      var truncated = text.length > MAX_CHARS
        ? text.substring(0, MAX_CHARS) + '\n\n...[TRUNCATED — ask about a specific topic for more detail]'
        : text;
      return { result: truncated };
    }

    function loadKnowledgeMap(course) {
      var text = getEmbedded('km-' + course);
      if (!text) return { error: 'Knowledge map for "' + course + '" not found.' };
      var truncated = text.length > MAX_CHARS
        ? text.substring(0, MAX_CHARS) + '\n\n...[KNOWLEDGE MAP TRUNCATED — ask about a specific section]'
        : text;
      return { result: truncated };
    }

    async function loadMaterial(course, filename, section) {
      var url = COURSES_PATH + '/' + course + '/materials/' + filename;
      var resp;
      try { resp = await fetch(url); }
      catch (e) { throw new Error('Material fetch failed (internet required) — ' + e.message); }
      if (!resp.ok) throw new Error('Material not found: HTTP ' + resp.status + ' — ' + url);
      var text = await resp.text();
      if (section) return { result: extractSection(text, section, MAX_CHARS) };
      var truncated = text.length > MAX_CHARS
        ? text.substring(0, MAX_CHARS) + '\n\n...[TRUNCATED — use section parameter to load a specific topic]'
        : text;
      return { result: truncated };
    }

    function saveProgress(course, topic, status, notes) {
      var store = getStore();
      if (!store.progress) store.progress = {};
      if (!store.progress[course]) store.progress[course] = {};
      var ex = store.progress[course][topic] || { sessionCount: 0 };
      store.progress[course][topic] = {
        status: status || ex.status || 'in-progress',
        lastStudied: today(),
        sessionCount: (ex.sessionCount || 0) + 1,
        notes: notes || ex.notes || ''
      };
      store.activeCourse = course; saveStore(store);
      return { result: 'Progress saved: **' + topic + '** marked as **' + (status || 'in-progress') + '** (session ' + store.progress[course][topic].sessionCount + ').' };
    }

    function getProgress(course) {
      var store = getStore(), progress = store.progress || {};
      var courses = course ? [course] : COURSE_SLUGS, lines = [];
      for (var i = 0; i < courses.length; i++) {
        var c = courses[i], topics = progress[c];
        if (!topics || Object.keys(topics).length === 0) { lines.push('**' + c + '**: No topics studied yet.'); continue; }
        lines.push('\n**' + c + ':**');
        Object.entries(topics).forEach(function(kv) {
          var icon = kv[1].status === 'complete' ? '✓' : kv[1].status === 'in-progress' ? '→' : '○';
          lines.push('  ' + icon + ' ' + kv[0] + ' (' + kv[1].status + ', ' + kv[1].sessionCount + ' session' + (kv[1].sessionCount !== 1 ? 's' : '') + ', last: ' + kv[1].lastStudied + ')');
        });
      }
      var weakAreas = [];
      (store.quizHistory ? courses : []).forEach(function(c) {
        (store.quizHistory[c] || []).forEach(function(e) {
          if (e.score < 0.6) weakAreas.push('  - ' + e.topic + ' (' + c + '): ' + Math.round(e.score*100) + '% on ' + e.date);
        });
      });
      if (weakAreas.length > 0) lines.push('\n**Areas needing review (< 60%):**\n' + weakAreas.slice(0,5).join('\n'));
      return { result: lines.length > 0 ? lines.join('\n') : 'No progress recorded yet. Start a learning session with **[LT]**.' };
    }

    function logQuiz(course, topic, score, difficulty, questionCount) {
      var store = getStore();
      if (!store.quizHistory) store.quizHistory = {};
      if (!store.quizHistory[course]) store.quizHistory[course] = [];
      store.quizHistory[course].unshift({ topic: topic, score: parseFloat(score), difficulty: difficulty || 'medium', questionCount: parseInt(questionCount)||0, date: today() });
      if (store.quizHistory[course].length > 50) store.quizHistory[course] = store.quizHistory[course].slice(0,50);
      saveStore(store);
      var pct = Math.round(parseFloat(score)*100);
      var fb = pct >= 80 ? 'Excellent work!' : pct >= 60 ? 'Good effort — review the weak spots.' : "Keep studying — you'll get there!";
      return { result: 'Quiz logged: **' + pct + '%** on **' + topic + '** (' + (difficulty||'medium') + ', ' + (questionCount||0) + ' questions). ' + fb };
    }

    function showDashboard(course) {
      var url = course ? 'dashboard.html?course=' + encodeURIComponent(course) : 'dashboard.html';
      return { result: 'Opening your progress dashboard.', webview: { url: url, aspectRatio: 1.6 } };
    }

    async function debugInfo() {
      var aiKm = getEmbedded('km-artificial-intelligence');
      var testUrl = COURSES_PATH + '/artificial-intelligence/knowledge-map.md';
      var fetchStatus = 'not attempted';
      try { var r = await fetch(testUrl); fetchStatus = 'HTTP ' + r.status + ' ' + r.statusText; }
      catch (e) { fetchStatus = 'FETCH ERROR — ' + e.message; }
      return { result: [
        '**Xara Debug Info**',
        'baseURI: ' + document.baseURI,
        'Embedded AI KM: ' + (aiKm ? 'OK (' + aiKm.length + ' chars)' : 'MISSING'),
        'GitHub material fetch: ' + fetchStatus,
        'localStorage: ' + (typeof localStorage !== 'undefined'),
        'fetch API: ' + (typeof fetch !== 'undefined')
      ].join('\n') };
    }

    // --- Main dispatcher ---
    // Edge Gallery contract: call ai_edge_gallery_get_result(jsonString), do NOT use return
    window.run_js_action = function(input) {
      function done(r) { ai_edge_gallery_get_result(JSON.stringify(r)); }
      try {
        var data = (typeof input === 'string') ? JSON.parse(input) : input;
        switch (data.action) {
          case 'list_courses':      done(listCourses()); break;
          case 'load_course':       done(loadCourse(data.course)); break;
          case 'load_knowledge_map':done(loadKnowledgeMap(data.course)); break;
          case 'load_material':     loadMaterial(data.course, data.filename, data.section).then(done).catch(function(e){done({error:e.message});}); break;
          case 'save_progress':     done(saveProgress(data.course, data.topic, data.status, data.notes)); break;
          case 'get_progress':      done(getProgress(data.course)); break;
          case 'log_quiz':          done(logQuiz(data.course, data.topic, data.score, data.difficulty, data.question_count)); break;
          case 'show_dashboard':    done(showDashboard(data.course)); break;
          case 'debug_info':        debugInfo().then(done).catch(function(e){done({error:e.message});}); break;
          default:                  done({ error: 'Unknown action: ' + data.action });
        }
      } catch(e) {
        ai_edge_gallery_get_result(JSON.stringify({ error: 'Xara Tutor error: ' + e.message }));
      }
    };
</script>
</body>
</html>
